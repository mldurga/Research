{
  "PISystem": {
    "AFServer": "your-af-server-name",
    "PIDataArchive": "your-pi-data-archive-name",
    "DefaultDatabase": "your-default-database",
    "ConnectionTimeout": 30,
    "UseWindowsAuth": true
  },
  "PIWebAPI": {
    "BaseUrl": "https://your-piwebapi-server/piwebapi",
    "AuthMode": "kerberos",
    "Username": "",
    "Password": "",
    "VerifySSL": true
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "DefaultModel": "llama3",
    "TemperatureDefault": 0.7,
    "MaxTokens": 2048,
    "Models": {
      "local": ["llama3", "mistral", "codellama"],
      "frontier": {
        "openai": {
          "enabled": false,
          "apiKey": "",
          "model": "gpt-4"
        },
        "anthropic": {
          "enabled": false,
          "apiKey": "",
          "model": "claude-3-sonnet-20240229"
        }
      }
    }
  },
  "VectorDB": {
    "Type": "chromadb",
    "PersistDirectory": "./chroma_db",
    "CollectionName": "pi_metadata",
    "EmbeddingModel": "sentence-transformers/all-MiniLM-L6-v2",
    "ChunkSize": 500,
    "ChunkOverlap": 50
  },
  "Security": {
    "EnableWindowsAuth": true,
    "RequireElementPermissions": true,
    "RequirePointPermissions": true,
    "AllowedDomains": [],
    "AdminGroups": ["PI Vision Admins"],
    "CachePermissions": true,
    "CacheTTLSeconds": 300
  },
  "API": {
    "Host": "0.0.0.0",
    "Port": 8000,
    "EnableCORS": true,
    "AllowedOrigins": ["http://localhost:3000", "http://your-pivision-server"],
    "EnableSwagger": true,
    "LogLevel": "INFO"
  },
  "Agents": {
    "DefaultTimeout": 60,
    "MaxConcurrentAgents": 5,
    "EnableMCP": true,
    "MCPToolsDirectory": "./mcp_tools"
  },
  "Cache": {
    "EnableRedis": false,
    "RedisUrl": "redis://localhost:6379",
    "DefaultTTL": 300
  }
}
