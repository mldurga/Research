# PI Web API connection
PI_WEBAPI_URL=https://<pi-server>/piwebapi
AF_SERVER_NAME=<af-server-name>
AF_DATABASE_NAME=<af-database-name>
DATA_SERVER_NAME=<data-server-name>
PI_USERNAME=<username>
PI_PASSWORD=<password>
PI_AUTH_METHOD=basic            # basic | kerberos | negotiate | bearer
PI_VERIFY_SSL=false
PI_TIMEOUT=30

# Embedding model (local sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=cpu            # cpu | cuda

# ChromaDB
CHROMA_CLIENT_TYPE=persistent   # persistent | ephemeral | http | cloud
CHROMA_DATA_DIR=./chroma_data
CHROMA_COLLECTION=af_elements

# Knowledge Graph (NetworkX)
KG_ENABLED=true
KG_PERSIST_PATH=./graph_data
KG_MAX_DEPTH=10

# BM25 keyword index
BM25_ENABLED=true
BM25_PERSIST_PATH=./bm25_data

# Indexing pipeline
INDEXING_ENABLED=true
INDEXING_REFRESH_HOURS=24
INDEXING_BATCH_SIZE=50
INDEXING_MAX_ELEMENTS=10000
INDEXING_CONCURRENCY=20         # Parallel attribute fetches

# Query result cache
CACHE_ENABLED=true
CACHE_MAX_SIZE=500
CACHE_CURRENT_VALUE_TTL=30      # seconds
CACHE_SUMMARY_TTL=300
CACHE_HEALTH_TTL=60
CACHE_STRUCTURAL_TTL=600
CACHE_RESOLUTION_TTL=900
CACHE_FORECAST_TTL=3600

LOG_LEVEL=INFO
